generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model user {
  id                       String                     @id @default(auto()) @map("_id") @db.ObjectId
  email                    String                     @unique
  password                 String
  role                     String                     @default("CUSTOMER")
  firstName                String?
  lastName                 String?
  phone                    String?
  address                  String?
  licenseNumber            String?                    @unique
  licenseExpiryDate        DateTime?
  idCardUrl                String?
  licenseUrl               String?
  profileImageUrl          String?
  signatureUrl             String?
  isBlacklisted            Boolean                    @default(false)
  createdAt                DateTime                   @default(now())
  reservation              reservation[]
  passwordreset            passwordreset[]
  reservationStatusHistory reservationstatushistory[]
  paymentStatusHistory     paymentstatushistory[]
  checkouts                checkout[]
  checkins                 checkin[]
}

model passwordreset {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  code      String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      user     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model checkout {
  id            String      @id @default(auto()) @map("_id") @db.ObjectId
  reservationId String      @unique
  vehicleId     String
  mileageOut    Int
  createdAt     DateTime    @default(now())
  createdBy     String
  reservation   reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  vehicle       vehicle     @relation(fields: [vehicleId], references: [id])
  user          user        @relation(fields: [createdBy], references: [id])
}

model checkin {
  id            String      @id @default(auto()) @map("_id") @db.ObjectId
  reservationId String      @unique
  vehicleId     String
  mileageIn     Int
  damageReport  String?
  extraCharges  Float       @default(0)
  createdAt     DateTime    @default(now())
  createdBy     String
  reservation   reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  vehicle       vehicle     @relation(fields: [vehicleId], references: [id])
  user          user        @relation(fields: [createdBy], references: [id])
}

model maintenance {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  vehicleId   String
  type        String
  dueDate     DateTime
  dueMileage  Int?
  isCompleted Boolean  @default(false)
  isDeleted   Boolean  @default(false)
  completedAt DateTime?
  deletedAt   DateTime?
  vehicle     vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
}

model reservation {
  id                   String                     @id @default(auto()) @map("_id") @db.ObjectId
  vehicleId            String
  userId               String
  startDate            DateTime
  endDate              DateTime
  destination          String?
  pickupLocation       String?
  returnLocation       String?
  totalPrice           Float
  depositPaid          Float
  paymentStatus        String                     @default("UNPAID")
  status               String                     @default("PENDING")
  contractNumber       String                     @unique
  contractPdfUrl       String?
  createdAt            DateTime                   @default(now())
  checkin              checkin?
  checkout             checkout?
  user                 user                       @relation(fields: [userId], references: [id])
  vehicle              vehicle                    @relation(fields: [vehicleId], references: [id])
  statusHistory        reservationstatushistory[]
  paymentHistory       paymentstatushistory[]
}

model reservationstatushistory {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  reservationId String
  fromStatus    String
  toStatus      String
  changedBy     String
  reason        String?
  createdAt     DateTime @default(now())
  reservation   reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  user          user        @relation(fields: [changedBy], references: [id])
}

model paymentstatushistory {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  reservationId String
  fromStatus    String
  toStatus      String
  changedBy     String
  reason        String?
  createdAt     DateTime @default(now())
  reservation   reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  user          user        @relation(fields: [changedBy], references: [id])
}

model vehicle {
  id             String         @id @default(auto()) @map("_id") @db.ObjectId
  brand          String
  model          String
  year           Int?
  licensePlate   String         @unique
  category       String
  color          String?
  seats          Int?
  transmission   String?
  fuelType       String?
  description    String?
  features       String?
  dailyPrice     Float
  deposit        Float
  currentMileage Int            @default(0)
  status         String         @default("AVAILABLE")
  isAvailable    Boolean        @default(true)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  maintenance    maintenance[]
  reservation    reservation[]
  vehicleimage   vehicleimage[]
  checkouts      checkout[]
  checkins       checkin[]
}

model vehicleimage {
  id        String  @id @default(auto()) @map("_id") @db.ObjectId
  vehicleId String
  imageUrl  String
  vehicle   vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
}

model invoicesettings {
  id                String   @id @default(auto()) @map("_id") @db.ObjectId
  companyName       String   @default("Car Rental Company")
  ownerName         String?
  companyAddress    String?
  companyPhone      String?
  companyEmail      String?
  companyLogoUrl    String?
  termsConditions   String?
  footerMessage     String?
  adminSignatureUrl String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}